{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://provai.dev/schemas/aip/aip-registry/latest",
  "$comment": "Normatively defined in AIP spec §7.3.4. This schema describes the /.well-known/aip-registry discovery document.",
  "title": "AIP Registry Discovery Document",
  "description": "Discovery metadata published at /.well-known/aip-registry. This document identifies the Registry service and points verifiers to the current Registry Trust Record.",
  "type": "object",
  "required": [
    "registry_id",
    "registry_name",
    "aip_version",
    "registry_trust_uri",
    "endpoints"
  ],
  "additionalProperties": false,
  "properties": {
    "registry_id": {
      "type": "string",
      "format": "uri",
      "pattern": "^https://.+$"
    },
    "registry_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "aip_version": {
      "type": "string",
      "minLength": 1,
      "maxLength": 16
    },
    "registry_trust_uri": {
      "type": "string",
      "format": "uri",
      "pattern": "^https://.+$"
    },
    "endpoints": {
      "type": "object",
      "required": [
        "agents",
        "crl",
        "revocations"
      ],
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      },
      "properties": {
        "agents": {
          "type": "string",
          "minLength": 1
        },
        "crl": {
          "type": "string",
          "minLength": 1
        },
        "revocations": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
