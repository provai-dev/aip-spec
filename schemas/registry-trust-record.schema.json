{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://provai.dev/schemas/aip/registry-trust-record/latest",
  "$comment": "Normatively defined in AIP spec §7.3.4.1 and §7.3.6. This schema describes the canonical Registry Trust Record.",
  "title": "AIP Registry Trust Record",
  "description": "Versioned trust metadata for an AIP Registry. Verifiers use this object for trust bootstrapping, planned trust updates, rollback detection, and historical verification.",
  "type": "object",
  "required": [
    "signed",
    "signatures"
  ],
  "additionalProperties": false,
  "properties": {
    "signed": {
      "type": "object",
      "required": [
        "registry_id",
        "version",
        "issued_at",
        "expires_at",
        "discovery_uri",
        "endpoints",
        "trust_signature_threshold",
        "trusted_keys",
        "active_verification_keys"
      ],
      "additionalProperties": false,
      "properties": {
        "registry_id": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://.+$"
        },
        "version": {
          "type": "integer",
          "minimum": 1
        },
        "issued_at": {
          "type": "string",
          "format": "date-time"
        },
        "expires_at": {
          "type": "string",
          "format": "date-time"
        },
        "discovery_uri": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://.+$"
        },
        "endpoints": {
          "type": "object",
          "required": [
            "agents",
            "crl",
            "revocations"
          ],
          "additionalProperties": {
            "type": "string",
            "minLength": 1
          },
          "properties": {
            "agents": {
              "type": "string",
              "minLength": 1
            },
            "crl": {
              "type": "string",
              "minLength": 1
            },
            "revocations": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "trust_signature_threshold": {
          "type": "integer",
          "minimum": 1,
          "description": "Minimum number of signatures from trusted_keys required for ordinary acceptance of this trust record."
        },
        "trusted_keys": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/jwk_with_keyid"
          }
        },
        "active_verification_keys": {
          "type": "object",
          "required": [
            "step_execution",
            "crl",
            "notifications"
          ],
          "additionalProperties": false,
          "properties": {
            "step_execution": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "format": "uri-reference"
              }
            },
            "crl": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "format": "uri-reference"
              }
            },
            "notifications": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "format": "uri-reference"
              }
            }
          }
        }
      }
    },
    "signatures": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "keyid",
          "sig"
        ],
        "additionalProperties": false,
        "properties": {
          "keyid": {
            "type": "string",
            "format": "uri-reference"
          },
          "sig": {
            "type": "string",
            "pattern": "^[A-Za-z0-9_-]+$"
          }
        }
      }
    }
  },
  "$defs": {
    "jwk_with_keyid": {
      "type": "object",
      "required": [
        "kty",
        "crv",
        "x",
        "keyid"
      ],
      "additionalProperties": false,
      "properties": {
        "kty": {
          "type": "string",
          "const": "OKP"
        },
        "crv": {
          "type": "string",
          "const": "Ed25519"
        },
        "x": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_-]{43}$"
        },
        "keyid": {
          "type": "string",
          "format": "uri-reference"
        }
      }
    }
  }
}
